{
  "manifest_version": 3,
  "name": "Inven Clear",
  "version": "0.1.1",
  "description": "인벤 '내 글/내 댓글' 목록에서 체크박스로 여러 글을 한 번에 삭제합니다.",
  "icons": {
    "16": "img/icons/icon16.png",
    "32": "img/icons/icon32.png",
    "48": "img/icons/icon48.png",
    "128": "img/icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "img/icons/icon16.png",
      "32": "img/icons/icon32.png",
      "48": "img/icons/icon48.png",
      "128": "img/icons/icon128.png"
    },
    "default_title": "Inven Clear"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.inven.co.kr/board/*"
      ],
      "js": [
        "shared/util.js",
        "shared/table.js",
        "features/posts.js",
        "features/comments.js",
        "content.js"
      ],
      "css": [
        "styles/base.css",
        "styles/posts.css",
        "styles/comments.css"
      ],
      "run_at": "document_end"
    }
  ],
  "host_permissions": [
    "https://www.inven.co.kr/*"
  ]
}
